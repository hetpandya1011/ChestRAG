# Copy this to `.env` and fill in real values. `.env` is gitignored.
# For the EMPTY STACK you don't need any API keys yet — the defaults below are enough.

# --- Postgres / pgvector ---
POSTGRES_USER=chestrag
POSTGRES_PASSWORD=chestrag
POSTGRES_DB=chestrag
POSTGRES_PORT=5432
# POSTGRES_HOST is intentionally unset: local scripts default to "localhost";
# docker-compose sets it to "db" for the API container.

# --- Service wiring ---
# How the web (Streamlit) container reaches the api container over the compose network.
# "api" is the service name in docker-compose.yml; Docker's DNS resolves it.
API_URL=http://api:8000

# --- App ---
LOG_LEVEL=INFO

# --- LLM / embeddings (needed later, in the ingest + generation steps) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
